{
  "manifest_version": 3,
  "name": "Booking.com Price Tracker",
  "version": "1.1.0",
  "description": "Track hotel prices on Booking.com and get alerted when they drop below your target.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.booking.com/*",
    "https://booking-price-tracker-production-6ff2.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": [ "*://*.booking.com/hotel/*" ],
      "js": [ "content.js" ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  }
}
