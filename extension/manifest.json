{
  "manifest_version": 3,
  "name": "Booking.com Price Tracker",
  "version": "1.0.0",
  "description": "Track hotel prices on Booking.com and get alerted when they drop below your target.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.booking.com/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  }
}
